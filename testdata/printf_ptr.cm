/* printf_ptr.cm — test P2-B: %p pointer format */
#include <stdio.h>

int main(void) {
    char* p;
    long addr;

    /* known small address: cast int to pointer */
    addr = 42;
    p = (char*)addr;
    printf("%p\n", p);

    /* NULL pointer */
    p = (char*)0;
    printf("%p\n", p);

    /* larger address */
    addr = 0xdeadbeef;
    p = (char*)addr;
    printf("%p\n", p);

    return 0;
}
