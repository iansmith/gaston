/* sizeof_basic.cm — sizeof(type), sizeof(expr), sizeof(struct) */
struct Pair { int a; int b; };

void main(void) {
    int x;
    char c;
    int *p;
    struct Pair pr;
    output(sizeof(int));         /* 8 */
    output(sizeof(char));        /* 1 */
    output(sizeof(x));           /* 8  — int var */
    output(sizeof(c));           /* 1  — char var */
    output(sizeof(p));           /* 8  — int* pointer */
    output(sizeof(struct Pair)); /* 16 — 2-field struct */
    output(sizeof(pr));          /* 16 — struct Pair var */
}
