/* float_neg: unary negation */
int main(void) {
    double x;
    int n;
    x = 3.5;
    x = -x;
    x = -x;
    n = x;
    output(n);     /* 3  (3.5 → 3) */
    x = -3.5;
    x = x + 4.5;
    n = x;
    output(n);     /* 1  (1.0) */
    x = -3.5;
    x = x * -2.0;
    n = x;
    output(n);     /* 7  (7.0) */
    return 0;
}
