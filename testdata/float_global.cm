/* float_global: global double variables */
double g;
double h;
int main(void) {
    int n;
    g = 7.5;
    h = 2.5;
    n = g + h;
    output(n);    /* 10 */
    n = g - h;
    output(n);    /* 5 */
    n = g * h;
    output(n);    /* 18  (18.75 → 18) */
    g = g + 0.5;
    n = g;
    output(n);    /* 8 */
    return 0;
}
