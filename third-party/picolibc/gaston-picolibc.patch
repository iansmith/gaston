+++ picolibc-patched/cmd/gaston/picolibc/libc/string/strdup_r.c	2026-04-08 22:31:47
@@ -0,0 +1,18 @@
+/*
+Copyright (c) 2002 Jeff Johnston <jjohnstn@redhat.com>
+ */
+#include <stdlib.h>
+#include <string.h>
+
+char *
+_strdup_r (struct _reent *reent_ptr,
+        const char   *str)
+{
+  size_t len = strlen (str) + 1;
+  char *copy = _malloc_r (reent_ptr, len);
+  if (copy)
+    {
+      memcpy (copy, str, len);
+    }
+  return copy;
+}
