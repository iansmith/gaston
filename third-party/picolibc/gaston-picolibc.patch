+/* malloc.h -- header file for memory routines.  */
+
+#ifndef _INCLUDE_MALLOC_H_
+#define _INCLUDE_MALLOC_H_
+
+#include <sys/cdefs.h>
+#define __need_size_t
+#include <stddef.h>
