-int
-fcvtl_r (long double invalue,
-        int ndecimal,
-        int *decpt,
-        int *sign,
-        char *buf,
-        size_t len)
-{
-    struct dtoa dtoa;
-    int ntrailing;      /* number of zeros to add after the value */
-    int ndigit;         /* numer of generated digits */
-    int dtoa_decimal = ndecimal;
-    char *digits = dtoa.digits;
