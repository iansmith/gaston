static  double_t
roundtoint(double_t x)
{
    return round(x);
}

 


static  int32_t
converttoint(double_t x)
{



    return (long)round(x);

}







typedef double __float64;






static  uint32_t
asuint(float f)
{





    union {
        float    f;
        uint32_t i;
    } u = { f };
    return u.i;

}

static  float
asfloat(uint32_t i)
{





    union {
        uint32_t i;
        float    f;
    } u = { i };
    return u.f;

}

static  int32_t
_asint32(float f)
{
    return (int32_t)asuint(f);
}

static  int
_sign32(int32_t ix)
{
    return ((uint32_t)ix) >> 31;
}

static  int
_exponent32(int32_t ix)
{
    return (ix >> 23) & 0xff;
}

static  int32_t
_significand32(int32_t ix)
{
    return ix & 0x7fffff;
}

static  float
_asfloat(int32_t i)
{
    return asfloat((uint32_t)i);
}

static  int
issignalingf_inline(float x)
{
    uint32_t ix = asuint(x);
    if (!1)
        return (ix & 0x7fc00000u) == 0x7fc00000u;
    return 2 * (ix ^ 0x00400000u) > 0xFF800000u;
}


static  int
_sign64(int64_t ix)
{
    return ((uint64_t)ix) >> 63;
}

static  int
_exponent64(int64_t ix)
{
    return (ix >> 52) & 0x7ff;
}

static  int64_t
_significand64(int64_t ix)
{
    return ix & 0xfffffffffffffLL;
}

static  uint64_t
asuint64(__float64 f)
{





    union {
        __float64 f;
        uint64_t  i;
    } u = { f };
    return u.i;

}

static  __float64
asfloat64(uint64_t i)
{





    union {
        uint64_t  i;
        __float64 f;
    } u = { i };
    return u.f;

}

static  int64_t
_asint64(__float64 f)
{
    return (int64_t)asuint64(f);
}

static  __float64
_asfloat64(int64_t i)
{
    return asfloat64((uint64_t)i);
}

static  int
issignaling64_inline(__float64 x)
{
    uint64_t ix = asuint64(x);
    if (!1)
        return (ix & 0x7ff8000000000000ULL) == 0x7ff8000000000000ULL;
    return 2 * (ix ^ 0x0008000000000000ULL) > 2 * 0x7ff8000000000000ULL;
}


 












































static  float
opt_barrier_float(float x)
{
    volatile float y = x;
    return y;
}

static  double
opt_barrier_double(double x)
{
    volatile double y = x;
    return y;
}

static  void
force_eval_float(float x)
{
    volatile float y = x;
    (void)y;
}

static  void
force_eval_double(double x)
{
    volatile double y = x;
    (void)y;
}


static  long double
opt_barrier_long_double(long double x)
{
    volatile long double y = x;
    return y;
}

static  void
force_eval_long_double(long double x)
{
    volatile long double y = x;
    (void)y;
}


 




































































 











































































































































































































































































































































































































































































































 






























































































 



static  float
eval_as_float(float x)
{
    return x;
}
static  double
eval_as_double(double x)
{
    return x;
}

 






 


 
